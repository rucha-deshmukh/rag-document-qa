# LLM provider
ANTHROPIC_API_KEY=your-key-here

# Database (pgvector-enabled Postgres)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rag

# Models
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=claude-sonnet-5

# Retrieval / chunking
TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# App
LOG_LEVEL=INFO
